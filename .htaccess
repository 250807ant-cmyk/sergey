# ============================================================
#  сергей-бог.рф — конфигурация Apache (Timeweb)
#  HTTPS + единый основной домен + кэш + сжатие
# ============================================================

Options -Indexes
DirectoryIndex index.html
AddDefaultCharset UTF-8

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- 1. Принудительный HTTPS ---
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://xn----btbecgb2a6bmi.xn--p1ai/$1 [R=301,L]

  # --- 2. Все прочие домены и www → основной сергей-бог.рф ---
  #     (sergey-bog.ru, sergeybog.ru, бог-сергей.рф, сергейбогданов.рф,
  #      сергей-богданов.рф, s-bogdanov.ru, www.* — всё ведёт сюда)
  RewriteCond %{HTTP_HOST} !^xn----btbecgb2a6bmi\.xn--p1ai$ [NC]
  RewriteRule ^(.*)$ https://xn----btbecgb2a6bmi.xn--p1ai/$1 [R=301,L]
</IfModule>

# --- Кэширование статики ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 30 days"
  ExpiresByType application/javascript "access plus 30 days"
  ExpiresByType image/jpeg "access plus 180 days"
  ExpiresByType image/png "access plus 180 days"
  ExpiresByType image/webp "access plus 180 days"
  ExpiresByType image/svg+xml "access plus 180 days"
  ExpiresByType font/woff2 "access plus 365 days"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# --- Сжатие ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
